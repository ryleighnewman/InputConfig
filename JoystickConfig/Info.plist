<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleDisplayName</key>
	<string>JoystickConfig</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>JoystickConfig</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>1.2</string>
	<key>CFBundleVersion</key>
	<string>9</string>
	<key>LSApplicationCategoryType</key>
	<string>public.app-category.utilities</string>
	<key>LSMinimumSystemVersion</key>
	<string>$(MACOSX_DEPLOYMENT_TARGET)</string>
	<key>NSAppSleepDisabled</key>
	<true/>
	<key>NSHumanReadableCopyright</key>
	<string>Copyright © 2026 Ryleigh Newman. All rights reserved.</string>
	<key>NSHighResolutionCapable</key>
	<true/>
	<!--
		Bluetooth usage description. CoreBluetooth / IOBluetooth aren't
		called directly, but the GameController framework opens an
		implicit Bluetooth connection when the user pairs a DualSense,
		DualShock 4, Switch Pro, or 8BitDo controller wirelessly. macOS
		shows this string in the connection prompt; App Store review
		rejects bundles that consume the Bluetooth pairing without
		declaring a purpose string.
	-->
	<key>NSBluetoothAlwaysUsageDescription</key>
	<string>JoystickConfig reads input from wireless game controllers paired with your Mac.</string>
	<key>NSBluetoothPeripheralUsageDescription</key>
	<string>JoystickConfig reads input from wireless game controllers paired with your Mac.</string>
	<!--
		Input Monitoring is required for the system-wide CGEventTap that
		reads the built-in keyboard / trackpad as binding inputs, AND for
		IOHIDManager to enumerate external USB keyboards / mice. Without
		this string, macOS Sequoia and later silently deny the request
		on first launch.
	-->
	<key>NSInputMonitoringUsageDescription</key>
	<string>JoystickConfig watches keyboard and mouse events so they can be used as bindings alongside game controllers.</string>
	<!--
		Apple Events permission is requested by NSWorkspace.open() when an
		Automation rule launches an external app on preset activate. macOS
		Sonoma+ requires a declared purpose string before showing the
		consent prompt.
	-->
	<key>NSAppleEventsUsageDescription</key>
	<string>JoystickConfig launches the apps you configure in a preset's Automation rules when you activate that preset.</string>
</dict>
</plist>
